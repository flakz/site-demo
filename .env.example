NEXT_PUBLIC_SUGGEST_1_PROMPT="How do I get started with the platform?"

NEXT_PUBLIC_SUGGEST_2_LABEL="See templates"
NEXT_PUBLIC_SUGGEST_2_PROMPT="Can you show me the available templates?"

NEXT_PUBLIC_SUGGEST_3_LABEL="Pricing"
NEXT_PUBLIC_SUGGEST_3_PROMPT="What are the pricing plans available?"

NEXT_PUBLIC_SUGGEST_4_LABEL="Book a demo"
NEXT_PUBLIC_SUGGEST_4_PROMPT="I would like to book a demo."

NEXT_PUBLIC_SUGGEST_5_LABEL="Documentation"
NEXT_PUBLIC_SUGGEST_5_PROMPT="Where can I find the API documentation?"

